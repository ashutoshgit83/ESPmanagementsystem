{
  "welcomeFile": "/index.html",
  "authenticationMethod": "route",
  "routes": [
    {
      "source": "^/odata/v4/(.*)$",
      "target": "/odata/v4/$1",
      "destination": "srv-api",
      "authenticationType": "xsuaa",
      "csrfProtection": true
    },
    {
      "source": "^/supplier-management/(.*)$",
      "localDir": "../supplier-management/",
      "authenticationType": "xsuaa"
    },
    {
      "source": "^/customer-management/(.*)$",
      "localDir": "../customer-management/",
      "authenticationType": "xsuaa"
    },
    {
      "source": "^/purchase-orders/(.*)$",
      "localDir": "../purchase-orders/",
      "authenticationType": "xsuaa"
    },
    {
      "source": "^/invoice-management/(.*)$",
      "localDir": "../invoice-management/",
      "authenticationType": "xsuaa"
    },
    {
      "source": "^/consumption-tracking/(.*)$",
      "localDir": "../consumption-tracking/",
      "authenticationType": "xsuaa"
    },
    {
      "source": "^/financial-planning/(.*)$",
      "localDir": "../financial-planning/",
      "authenticationType": "xsuaa"
    },
    {
      "source": "^/analytics-dashboard/(.*)$",
      "localDir": "../analytics-dashboard/",
      "authenticationType": "xsuaa"
    },
    {
      "source": "^/data-import/(.*)$",
      "localDir": "../data-import/",
      "authenticationType": "xsuaa"
    },
    {
      "source": "^(.*)$",
      "localDir": ".",
      "authenticationType": "xsuaa"
    }
  ]
}
