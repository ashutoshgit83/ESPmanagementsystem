{
  "_version": "1.59.0",
  "sap.app": {
    "id": "esp.reporting",
    "type": "application",
    "title": "Financial Controlling & Reporting",
    "description": "Multi-dimensional reporting: BP vs CFC vs Actuals, exchange rates, FTE metrics",
    "applicationVersion": { "version": "1.0.0" },
    "dataSources": {
      "mainService": {
        "uri": "../odata/v4/reporting/",
        "type": "OData",
        "settings": { "odataVersion": "4.0" }
      }
    }
  },
  "sap.ui5": {
    "flexEnabled": false,
    "dependencies": {
      "minUI5Version": "1.120.45",
      "libs": { "sap.ui.core": {}, "sap.fe.templates": {} }
    },
    "models": {
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": { "synchronizationMode": "None", "operationMode": "Server", "autoExpandSelect": true, "earlyRequests": true }
      }
    },
    "routing": {
      "routes": [
        { "pattern": ":?query:", "name": "PlanLinesList", "target": "PlanLinesList" },
        { "pattern": "PlanLines({key}):?query:", "name": "PlanLinesDetail", "target": "PlanLinesDetail" }
      ],
      "targets": {
        "PlanLinesList": {
          "type": "Component",
          "id": "PlanLinesList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "contextPath": "/PlanLines",
              "variantManagement": "Page",
              "navigation": { "PlanLines": { "detail": { "route": "PlanLinesDetail" } } },
              "initialLoad": "Enabled"
            }
          }
        },
        "PlanLinesDetail": {
          "type": "Component",
          "id": "PlanLinesDetail",
          "name": "sap.fe.templates.ObjectPage",
          "options": { "settings": { "contextPath": "/PlanLines", "editableHeaderContent": false } }
        }
      }
    }
  }
}
